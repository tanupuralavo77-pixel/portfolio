---
import type { Work } from '../data/works';

interface Props {
  work: Work;
}

const { work } = Astro.props;
---

<article class="rounded-lg border border-border bg-card overflow-hidden">
  <img
    src={work.image ?? `https://picsum.photos/seed/${work.imageSeed}/800/500`}
    alt={`${work.title}のスクリーンショット`}
    class="w-full aspect-video object-cover"
    loading="lazy"
  />
  <div class="p-6 sm:p-8">
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
      <h3 class="text-xl font-bold text-primary">{work.title}</h3>
      <p class="text-sm font-semibold text-accent whitespace-nowrap">
        制作費用目安: ¥{work.price.toLocaleString()}
      </p>
    </div>
    <p class="mt-1 text-xs text-muted">架空クライアント想定の自主制作</p>
    <p class="mt-3 text-sm text-secondary leading-relaxed">{work.description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {work.tags.map((tag) => (
        <span class="text-xs text-accent bg-accent/10 rounded-full px-3 py-1">{tag}</span>
      ))}
    </div>
    <a
      href={work.url}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-block text-sm text-accent hover:text-secondary transition-colors"
    >
      サイトを見る →
    </a>
  </div>
</article>
