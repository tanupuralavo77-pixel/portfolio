---
const snsLinks = [
  { href: 'https://x.com/web_craftweb_77', label: 'X' },
  { href: 'https://www.instagram.com/web_craftweb_77/', label: 'Instagram' },
];
---

<footer class="mt-16 border-t border-border bg-card">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-primary font-bold">WEBCRAFT</p>
    <p class="text-xs text-muted">&copy; {new Date().getFullYear()} WEBCRAFT</p>
    <div class="flex gap-4 text-sm">
      {snsLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-secondary transition-colors">{link.label}</a>
      ))}
    </div>
  </div>
</footer>
