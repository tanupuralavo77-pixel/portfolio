<!--
  NOTE: EmailJS の SERVICE_ID / TEMPLATE_ID / PUBLIC_KEY はプレースホルダーです。
  EmailJS (https://www.emailjs.com/) でアカウントを作成し、実際の値に置き換えてください。
  - TEMPLATE_ID_NOTIFY   : 自分(管理者)宛の通知メール用テンプレート
  - TEMPLATE_ID_AUTOREPLY: お客様宛の自動返信メール用テンプレート({{hearing_url}} を本文に含める)
-->
<form id="contact-form" class="space-y-5" novalidate>
  <div>
    <label for="name" class="block text-sm font-medium text-primary">
      お名前 <span class="text-destructive">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-3 text-sm text-primary focus:outline-none focus:ring-2 focus:ring-accent"
    />
    <p data-error-for="name" class="mt-1 text-xs text-destructive hidden">お名前を入力してください。</p>
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-primary">
      メールアドレス <span class="text-destructive">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-3 text-sm text-primary focus:outline-none focus:ring-2 focus:ring-accent"
    />
    <p data-error-for="email" class="mt-1 text-xs text-destructive hidden">正しいメールアドレスを入力してください。</p>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-primary">
      ご相談内容 <span class="text-destructive">*</span>
    </label>
    <p class="mt-1 text-xs text-muted">当てはまるものがあれば選択してください(複数選択可)</p>

    <div id="category-tags" class="mt-3 flex flex-wrap gap-2">
      {
        [
          '店舗サイト制作',
          'LP制作',
          '既存サイトのリニューアル',
          'デザインだけ相談したい',
          'まだ内容が固まっていない',
        ].map((tag) => (
          <button
            type="button"
            data-tag={tag}
            class="tag-button rounded-full border border-border px-3 py-1.5 text-xs text-secondary transition-colors hover:border-accent hover:text-accent"
          >
            {tag}
          </button>
        ))
      }
    </div>
    <input type="hidden" id="category" name="category" />

    <textarea
      id="message"
      name="message"
      rows="5"
      required
      placeholder="選択したタグに応じて、記入のヒントが表示されます"
      class="mt-3 w-full rounded-lg border border-border bg-bg px-4 py-3 text-sm text-primary focus:outline-none focus:ring-2 focus:ring-accent"
    ></textarea>
    <p data-error-for="message" class="mt-1 text-xs text-destructive hidden">ご相談内容を入力してください。</p>
  </div>

  <button
    type="submit"
    class="w-full min-h-11 rounded-lg bg-accent text-white text-sm font-medium px-6 py-3 hover:bg-secondary transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
  >
    送信する
  </button>

  <p id="form-status" role="status" aria-live="polite" class="text-sm text-center hidden"></p>
</form>

<script>
  import emailjs from '@emailjs/browser';

  const EMAILJS_SERVICE_ID = 'service_f8ncgrn';
  const EMAILJS_TEMPLATE_ID_NOTIFY = 'template_5lah768';
  const EMAILJS_TEMPLATE_ID_AUTOREPLY = 'template_49ozfxm';
  const EMAILJS_PUBLIC_KEY = '15WunddXX3jgvhdIg';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLParagraphElement;
  const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  const categoryTagsContainer = document.getElementById('category-tags') as HTMLDivElement;
  const categoryInput = document.getElementById('category') as HTMLInputElement;
  const messageTextarea = document.getElementById('message') as HTMLTextAreaElement;

  const tagHints: Record<string, string> = {
    '店舗サイト制作': '例:お店の業種、伝えたい魅力、希望のページ数などをご記入ください。',
    'LP制作': '例:広告の目的、ターゲット、必要なページ構成などをご記入ください。',
    '既存サイトのリニューアル': '例:現在のサイトURLと、改善したい点をご記入ください。',
    'デザインだけ相談したい': '例:希望するテイストや、参考にしたいサイトなどをご記入ください。',
    'まだ内容が固まっていない': 'まだ漠然としたイメージで大丈夫です。気になっている点だけでもお聞かせください。',
  };
  const defaultPlaceholder = '選択したタグに応じて、記入のヒントが表示されます';
  const selectedTags = new Set<string>();

  function updateMessagePlaceholder() {
    if (selectedTags.size === 0) {
      messageTextarea.placeholder = defaultPlaceholder;
      return;
    }
    const hints = Array.from(selectedTags).map((tag) => tagHints[tag]).filter(Boolean);
    messageTextarea.placeholder = hints[hints.length - 1] ?? defaultPlaceholder;
  }

  categoryTagsContainer.querySelectorAll<HTMLButtonElement>('.tag-button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? '';
      if (selectedTags.has(tag)) {
        selectedTags.delete(tag);
        btn.classList.remove('bg-accent', 'text-white', 'border-accent');
        btn.classList.add('text-secondary');
      } else {
        selectedTags.add(tag);
        btn.classList.add('bg-accent', 'text-white', 'border-accent');
        btn.classList.remove('text-secondary');
      }
      categoryInput.value = Array.from(selectedTags).join('、');
      updateMessagePlaceholder();
    });
  });

  const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function setFieldError(fieldName: string, hasError: boolean) {
    const errorEl = form.querySelector(`[data-error-for="${fieldName}"]`);
    if (errorEl) errorEl.classList.toggle('hidden', !hasError);
  }

  function validate(): boolean {
    const nameInput = form.elements.namedItem('name') as HTMLInputElement;
    const emailInput = form.elements.namedItem('email') as HTMLInputElement;
    const messageInput = form.elements.namedItem('message') as HTMLTextAreaElement;

    const nameValid = nameInput.value.trim().length > 0;
    const emailValid = emailPattern.test(emailInput.value.trim());
    const messageValid = messageInput.value.trim().length > 0;

    setFieldError('name', !nameValid);
    setFieldError('email', !emailValid);
    setFieldError('message', !messageValid);

    return nameValid && emailValid && messageValid;
  }

  function showStatus(text: string, colorClass: string) {
    statusEl.className = `text-sm text-center ${colorClass}`;
    statusEl.textContent = text;
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!validate()) {
      showStatus('入力内容をご確認ください。', 'text-destructive');
      return;
    }

    submitButton.disabled = true;
    showStatus('送信中です…', 'text-muted');

    const nameInput = form.elements.namedItem('name') as HTMLInputElement;
    const emailInput = form.elements.namedItem('email') as HTMLInputElement;
    const hearingUrl = new URL('/hearing', window.location.origin).href;

    const notifyParams = {
      name: nameInput.value,
      email: emailInput.value,
      category: categoryInput.value,
      message: messageTextarea.value,
    };
    const autoreplyParams = {
      to_name: nameInput.value,
      to_email: emailInput.value,
      hearing_url: hearingUrl,
    };

    try {
      const [notifyResult, autoreplyResult] = await Promise.all([
        emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID_NOTIFY, notifyParams, {
          publicKey: EMAILJS_PUBLIC_KEY,
        }),
        emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID_AUTOREPLY, autoreplyParams, {
          publicKey: EMAILJS_PUBLIC_KEY,
        }),
      ]);

      if (notifyResult.status === 200 && autoreplyResult.status === 200) {
        showStatus('送信しました。ご入力のメールに事前ヒアリングシートをお送りしました。', 'text-accent');
        form.reset();
        selectedTags.clear();
        categoryTagsContainer.querySelectorAll<HTMLButtonElement>('.tag-button').forEach((btn) => {
          btn.classList.remove('bg-accent', 'text-white', 'border-accent');
          btn.classList.add('text-secondary');
        });
        updateMessagePlaceholder();
      } else {
        showStatus('送信に失敗しました。時間をおいて再度お試しください。', 'text-destructive');
      }
    } catch {
      showStatus('送信に失敗しました。時間をおいて再度お試しください。', 'text-destructive');
    } finally {
      submitButton.disabled = false;
    }
  });
</script>
